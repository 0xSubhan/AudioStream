# ==============================================================================
# AudioStream .gitignore
# ==============================================================================

# 0. Android Signing (NEVER commit)
android_app/android/key.properties
android_app/android/app/*.jks
android_app/android/app/*.keystore

# 1. Build & Compilation Artifacts
build/
bin/
/lib/
CMakeLists.txt.user
CMakeCache.txt
CMakeFiles/
CMakeTargetDirectories.txt
Makefile
cmake_install.cmake
compile_commands.json

# 2. Local Libraries & Package Extractions (keep the folder but ignore the contents)
third_party/extracted/
third_party/debs/

# 3. Compiled Objects
*.o
*.a
*.so
*.so.*
*.la
*.lo
*.dylib
*.dll
*.exe

# 4. Test Recordings & Temporary Media
*.wav
output_capture.wav

# 5. Android & Flutter Build Artifacts
android_app/build/
android_app/.dart_tool/
android_app/.flutter-plugins
android_app/.flutter-plugins-dependencies
android_app/android/.gradle/
android_app/android/app/build/
android_app/android/local.properties
android_app/pubspec.lock
*.apk
*.aab

# 6. IDE & Editor Files
.vscode/
.clangd
.cache/
.~lock.*
.idea/
*.suo
*.user
*.ncb
*.pdb
.DS_Store

# 6. Python Virtual Environments and PyCache
venv/
.venv/
__pycache__/
*.pyc
*.so
